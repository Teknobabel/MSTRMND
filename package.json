{
  "name": "mastermind",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "content:validate": "tsx scripts/validate-content.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run content:validate && npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "zod": "^3.24.1"
  }
}
